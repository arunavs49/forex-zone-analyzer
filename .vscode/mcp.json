{
  // MCP server configurations for VS Code / GitHub Copilot
  // See: https://code.visualstudio.com/docs/copilot/chat/mcp-servers

  "inputs": [
    {
      "id": "mcp-token",
      "type": "promptString",
      "description": "Paste Entra ID token. Run in terminal: az account get-access-token --resource api://c1bba0b6-1125-40c1-b496-0ef773bfd7b4 --query accessToken --output tsv",
      "password": true
    }
  ],

  "servers": {
    // ── Local development ──────────────────────────────────────────────
    // No auth required. Start the server first:
    //   cd src/ForexZoneAnalyzer.McpServer
    //   dotnet user-secrets set "Oanda:ApiToken" "<your-oanda-token>"
    //   dotnet run
    //"forex-zone-analyzer-local": {
    //  "type": "http",
    //  "url": "http://localhost:5000/mcp"
    //}

    // ── Remote Azure deployment ────────────────────────────────────────
    // When starting, VS Code will prompt for a token.
    // Run this in a terminal first and paste the output:
    //   az account get-access-token --resource api://c1bba0b6-1125-40c1-b496-0ef773bfd7b4 --query accessToken --output tsv
    "forex-zone-analyzer-remote": {
       "type": "http",
       "url": "https://ca-forex-mcp.gentlegrass-9ef0e688.eastus2.azurecontainerapps.io/mcp",
       "headers": {
         "Authorization": "Bearer ${input:mcp-token}"
       }
    }
  }
}
